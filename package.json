{
  "name": "react-native-store-badges",
  "version": "1.0.7",
  "description": "A React Native library for rendering App Store and Google Play Store badges.",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "prepack": "bob build"
  },
  "keywords": [
    "react-native",
    "component",
    "app store",
    "google play",
    "badges"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usekeyhole/react-native-store-badges.git"
  },
  "author": "Keyhole",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/usekeyhole/react-native-store-badges/issues"
  },
  "homepage": "https://github.com/usekeyhole/react-native-store-badges#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-import": "^2.32.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "^0.85.2",
    "react-native-builder-bob": "^0.41.0",
    "react-native-web": "^0.21.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "main": "lib/commonjs/index.js",
  "react-native": "src/index.tsx",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index",
  "files": [
    "src",
    "lib"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "dependencies": {
    "react-native-svg": "^15.15.4",
    "react-svg": "^17.2.4"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
